# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# On Railway: automatically provided when you add the PostgreSQL plugin.
DATABASE_URL="postgresql://user:password@localhost:5432/rsvp_db"

# ── NextAuth (owner authentication) ───────────────────────────────────────────
# Random secret used to sign session tokens.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string-at-least-32-chars"

# Public URL of the app — required by NextAuth in production.
AUTH_URL="https://your-app.railway.app"

# OAuth — Google
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# OAuth — GitHub
# Create app at: https://github.com/settings/developers → OAuth Apps
# Callback URL: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# OAuth — Microsoft (Entra ID / Azure AD)
# Register app at: https://portal.azure.com → Entra ID → App registrations
# Redirect URI: {AUTH_URL}/api/auth/callback/microsoft-entra-id
# Scopes required: openid, profile, email
AUTH_MICROSOFT_ENTRA_ID_ID="your-azure-client-id"
AUTH_MICROSOFT_ENTRA_ID_SECRET="your-azure-client-secret"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="common"   # "common" for multi-tenant; or your tenant GUID

# ── Super-admin bootstrap ──────────────────────────────────────────────────────
# The seed script grants role="superadmin" to this email on first run.
# After seeding, additional superadmins are managed through the /super-admin UI.
SUPER_ADMIN_EMAIL="you@yourdomain.com"

# ── Twilio Verify (guest phone OTP — unchanged from v1) ───────────────────────
# Find Account SID and Auth Token at: https://console.twilio.com
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# Create a Verify Service: Twilio Console → Verify → Services (SID starts with "VA")
TWILIO_VERIFY_SERVICE_SID="VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Twilio Messaging (outbound SMS for notifications & invites) ────────────────
# Different from the Verify service — this is a regular Twilio phone number
# used for sending notification blasts and invite messages.
# Buy a number at: https://console.twilio.com → Phone Numbers → Buy a Number
TWILIO_PHONE_NUMBER="+15550000000"

# ── Email (owner notifications & invites) ─────────────────────────────────────
# Get your API key at: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# The "from" address for outbound emails. Must be a verified domain in Resend.
RESEND_FROM_EMAIL="events@yourdomain.com"

# ── Observability — Sentry ─────────────────────────────────────────────────────
# Create a Next.js project at: https://sentry.io → Projects → Create Project
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
# Auth token for source map uploads during CI/CD builds (not needed at runtime).
# Generate at: https://sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Observability — Axiom ─────────────────────────────────────────────────────
# Create a dataset and token at: https://app.axiom.co
AXIOM_DATASET="v0-guest-event-app"
AXIOM_TOKEN="xaat-xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── Uploadthing (file uploads) ────────────────────────────────────────────────
# Get your token at: https://uploadthing.com → create an app → copy the token.
UPLOADTHING_TOKEN="your_uploadthing_token"

# ── Unsplash image search ─────────────────────────────────────────────────────
# Get your Access Key at: https://unsplash.com/developers → create an app.
# Free tier: 50 req/hr (demo). Apply for production access for higher limits.
UNSPLASH_ACCESS_KEY="your_unsplash_access_key"

# ── App ───────────────────────────────────────────────────────────────────────
# Public URL used for absolute URL generation (OG images, invite links, etc.)
NEXT_PUBLIC_APP_URL="https://your-app.railway.app"
